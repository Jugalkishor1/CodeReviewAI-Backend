# GitHub OAuth App credentials (these identify YOUR APP — every user signs in with their own GitHub account)
# Create at: https://github.com/settings/developers → New OAuth App
GITHUB_CLIENT_ID=your_github_oauth_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret
# Must match the Authorization callback URL on the GitHub OAuth App (no trailing slash)
GITHUB_REDIRECT_URI=http://localhost:5173

# AI provider (set the one you use)
GROQ_API_KEY=your_groq_api_key
# GEMINI_API_KEY=your_gemini_api_key
# GEMINI_MODEL=gemini-2.0-flash

# Frontend origin(s) for CORS — REQUIRED in production
# Comma-separated if you need local + production:
# FRONTEND_ORIGIN=http://localhost:5173,https://code-review-ai-frontend-six.vercel.app
FRONTEND_ORIGIN=http://localhost:5173

# Rails (generated by bin/rails secret if missing)
# SECRET_KEY_BASE=
