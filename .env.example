# GitHub OAuth App credentials
# Create at: https://github.com/settings/developers → New OAuth App
GITHUB_CLIENT_ID=your_github_oauth_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret
# Must match the Authorization callback URL on the GitHub OAuth App
GITHUB_REDIRECT_URI=http://localhost:5173

# Gemini AI
# Create at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.0-flash

# Frontend origin for CORS
FRONTEND_ORIGIN=http://localhost:5173

# Rails (generated by bin/rails secret if missing)
# SECRET_KEY_BASE=
